# Steelcareer Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# SUPABASE CLIENT - PUBLIC (Safe to expose)
# ============================================================================
# Get these from your Supabase project settings:
# 1. Go to https://app.supabase.com/project/_/settings/api
# 2. Copy the "Project URL" and "Anon public" key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your_public_key_here

# ============================================================================
# SUPABASE AUTH REDIRECT
# Set this for email confirmation and OAuth callbacks
# For local development: http://localhost:3000
# For production: your Vercel domain
# ============================================================================

NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ============================================================================
# SUPABASE SERVICE ROLE - ADMIN ONLY
# ⚠️  CRITICAL SECURITY WARNING ⚠️
# 
# This key MUST NEVER be exposed publicly or in client-side code!
# Never commit this to git without encryption
# Only use in server-side API routes (app/api/*)
# 
# Do NOT include this in:
# - Client components ('use client')
# - Browser-accessible files
# - Frontend configuration
# 
# Get this from Supabase project settings (API tab, Service role key)
# ============================================================================

SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your_service_role_key_here

# ============================================================================
# OPTIONAL: Storage Configuration
# For file uploads to Supabase Storage buckets
# ============================================================================

# NEXT_PUBLIC_STORAGE_BUCKET_RESUMES=resumes
# NEXT_PUBLIC_STORAGE_BUCKET_DOCUMENTS=documents
